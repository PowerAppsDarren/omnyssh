{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmnySSH",
  "identifier": "com.timhartmann.omnyssh",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmnySSH",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "backgroundColor": "#171717",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
