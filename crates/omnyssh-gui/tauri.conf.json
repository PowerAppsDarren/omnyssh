{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OmnySSH",
  "identifier": "com.timhartmann.omnyssh",
  "build": {
    "frontendDist": "ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "cwd": "ui", "script": "npm run dev" },
    "beforeBuildCommand": { "cwd": "ui", "script": "npm run build" }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OmnySSH",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "backgroundColor": "#171717",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": []
    }
  }
}
